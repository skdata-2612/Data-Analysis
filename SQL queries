-- Are there seasonal or time-based purchase trends?

with sales_diff as
	(select extract(year from purchase_ts) as year,extract(month from purchase_ts) as month, 
	sum(usd_price) as revenue,
	lag(sum(usd_price)) over(order by extract(year from purchase_ts), 
	extract(month from purchase_ts)) as prev_sales
	from orders
	where purchase_ts is not null
	group by extract(year from purchase_ts), extract(month from purchase_ts))

select  month, revenue,
round((revenue-prev_sales)/prev_sales*100, 2) as prev_sales_diff
from sales_diff

with monthly_sales as (
    select 
        extract(year from purchase_ts) as year,
        extract(month from purchase_ts) as month,
        sum(usd_price) as revenue
    from orders
    where purchase_ts is not null
    group by extract(year from purchase_ts), extract(month from purchase_ts)
)
select 
    year,
    month,
    revenue,
    lag(revenue) over(partition by month order by year) as prev_year_revenue,
    round(
        (revenue - lag(revenue) over(partition by month order by year)) 
        / lag(revenue) over(partition by month order by year) * 100, 
        2
    ) as yoy_growth
from   monthly_sales
order by year, month;

